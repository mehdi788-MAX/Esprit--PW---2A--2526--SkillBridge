# =====================================================
# SkillBridge — variables d'environnement
# -----------------------------------------------------
# Copiez ce fichier en `.env` et renseignez les clés.
# La base de code lit `.env` via lib/env_loader.php
# au boot (cf. config.php).
# =====================================================

# ---------- OAuth providers ----------
# (Optionnel — laissez vide pour désactiver le bouton correspondant.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ---------- Assistant IA (Ollama local) ----------
# Endpoint du serveur Ollama. Par défaut, l'instance locale.
OLLAMA_API_URL=http://127.0.0.1:11434/api/chat

# Modèle utilisé pour la synthèse + suggestions (≈ 530 MB).
# Pull à faire une fois : `ollama pull qwen3:0.6b`
OLLAMA_MODEL=qwen3:0.6b
